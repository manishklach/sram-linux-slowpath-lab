From: Antigravity <antigravity@google.com>
Date: Sat, 2 May 2026 14:03:00 -0700
Subject: [PATCH 1/4] io_uring: trace whether requests use registered buffers

Add a 'fixed_buffers' field to io_uring_submit_req, io_uring_issue,
and io_uring_complete tracepoints. This allows userspace to verify
if the high-performance fixed-buffer path is actually being used.

Note: In io_uring_complete, the request pointer is cast to struct io_kiocb
to access the flags, with a NULL check as some completions may not
have an associated request.

Signed-off-by: Antigravity <antigravity@google.com>
---
 include/trace/events/io_uring.h | 115 ++++++++++++++++++++++++++++------------
 1 file changed, 81 insertions(+), 34 deletions(-)

diff --git a/include/trace/events/io_uring.h b/include/trace/events/io_uring.h
index ...
--- a/include/trace/events/io_uring.h
+++ b/include/trace/events/io_uring.h
@@ -333,6 +333,7 @@ TRACE_EVENT(io_uring_complete,
 		__field(  pid_t,		pid		)
 		__field(  pid_t,		tgid		)
 		__field(  bool,		low_latency	)
+		__field(bool,		fixed_buffers)
 	),
 
 	TP_fast_assign(
@@ -345,10 +346,11 @@ TRACE_EVENT(io_uring_complete,
 		__entry->pid		= current->pid;
 		__entry->tgid		= current->tgid;
 		__entry->low_latency	= !!(ctx->flags & IORING_SETUP_LOW_LATENCY);
+		__entry->fixed_buffers	= req ? !!(((struct io_kiocb *)req)->flags & REQ_F_BUF_NODE) : false;
 	),
 
 	TP_printk("ring %p, req %p, user_data 0x%llx, result %d, cflags 0x%x "
-		  "extra1 %llu extra2 %llu pid %d tgid %d low_latency %d",
+		  "extra1 %llu extra2 %llu pid %d tgid %d low_latency %d fixed_buffers %d",
 		__entry->ctx, __entry->req,
 		__entry->user_data,
 		__entry->res, __entry->cflags,
@@ -357,7 +359,8 @@ TRACE_EVENT(io_uring_complete,
 		(unsigned long long) __entry->extra1,
 		(unsigned long long) __entry->extra2,
-		__entry->pid, __entry->tgid, __entry->low_latency)
+		__entry->pid, __entry->tgid, (int)__entry->low_latency,
+		(int)__entry->fixed_buffers)
 );
 
 /**
+ * io_uring_submit_req - called before submitting a request
+ */
+TRACE_EVENT(io_uring_submit_req,
+
+	TP_PROTO(struct io_kiocb *req),
+
+	TP_ARGS(req),
+
+	TP_STRUCT__entry(
+		__field(void *,		ctx)
+		__field(void *,		req)
+		__field(unsigned long long, user_data)
+		__field(u8,		opcode)
+		__field(unsigned long long, flags)
+		__field(bool,		sq_thread)
+		__field(pid_t,		pid)
+		__field(pid_t,		tgid)
+		__field(bool,		fixed_buffers)
+
+		__string(op_str, io_uring_get_opcode(req->opcode))
+	),
+
+	TP_fast_assign(
+		__entry->ctx		= req->ctx;
+		__entry->req		= req;
+		__entry->user_data	= req->cqe.user_data;
+		__entry->opcode		= req->opcode;
+		__entry->flags		= (__force unsigned long long) req->flags;
+		__entry->sq_thread	= req->ctx->flags & IORING_SETUP_SQPOLL;
+		__entry->pid		= current->pid;
+		__entry->tgid		= current->tgid;
+		__entry->fixed_buffers	= !!(req->flags & REQ_F_BUF_NODE);
+
+		__assign_str(op_str);
+	),
+
+	TP_printk("ring %p, req %p, user_data 0x%llx, opcode %s, flags 0x%llx, "
+		  "sq_thread %d, pid %d, tgid %d, fixed_buffers %d", __entry->ctx, __entry->req,
+		  __entry->user_data, __get_str(op_str), __entry->flags,
+		  __entry->sq_thread, __entry->pid, __entry->tgid, __entry->fixed_buffers)
+);
+
+/**
  * io_uring_issue - called when a request is issued to the underlying op
-@@ -401,10 +404,11 @@ TRACE_EVENT(io_uring_issue,
+ */
+TRACE_EVENT(io_uring_issue,
+
+	TP_PROTO(struct io_kiocb *req),
+
+	TP_ARGS(req),
+
+	TP_STRUCT__entry(
+		__field(void *,		ctx)
+		__field(void *,		req)
+		__field(unsigned long long, user_data)
+		__field(u8,		opcode)
+		__field(pid_t,		pid)
+		__field(pid_t,		tgid)
+		__field(bool,		fixed_buffers)
+	),
+
+	TP_fast_assign(
+		__entry->ctx		= req->ctx;
+		__entry->req		= req;
+		__entry->user_data	= req->cqe.user_data;
+		__entry->opcode		= req->opcode;
+		__entry->pid		= current->pid;
+		__entry->tgid		= current->tgid;
+		__entry->fixed_buffers	= !!(req->flags & REQ_F_BUF_NODE);
+	),
+
+	TP_printk("ring %p, req %p, user_data 0x%llx, opcode %d, pid %d, tgid %d, fixed_buffers %d",
+		__entry->ctx, __entry->req, __entry->user_data, __entry->opcode,
+		__entry->pid, __entry->tgid, __entry->fixed_buffers)
+);

/*
 * io_uring latency attribution via kernel tracepoints.
 * Captures submit, issue, and complete events.
 */

BEGIN {
    printf("Tracing io_uring latency... Hit Ctrl-C to end.\n");
    printf("%-16s %-10s %-16s %-10s %-10s %-10s\n", "TIME", "PID", "EVENT", "REQ", "LATENCY", "MODE");
}

tracepoint:io_uring:io_uring_submit_req {
    @start[args->req] = nsecs;
    @submit_pid[args->req] = pid;
}

tracepoint:io_uring:io_uring_issue {
    if (@start[args->req]) {
        $lat = (nsecs - @start[args->req]) / 1000;
        printf("%-16llu %-10d %-16s %-10p %-10d %-10s %-5d\n", 
               nsecs, pid, "ISSUE", args->req, $lat, "-", args->fixed_buffers);
        @issue_ts[args->req] = nsecs;
    }
}

tracepoint:io_uring:io_uring_complete {
    if (@start[args->req]) {
        $total_lat = (nsecs - @start[args->req]) / 1000;
        printf("%-16llu %-10d %-16s %-10p %-10d %-10d %-5d\n", 
               nsecs, pid, "COMPLETE", args->req, $total_lat, args->low_latency, args->fixed_buffers);
               
        delete(@start[args->req]);
        delete(@issue_ts[args->req]);
        delete(@submit_pid[args->req]);
    }
}

tracepoint:io_uring:io_uring_cq_wakeup {
    printf("%-16llu %-10d %-16s %-10p %-10s %-10s\n", 
           nsecs, pid, "CQ_WAKEUP", args->ctx, "-", "-");
}
